# Required
BOT_TOKEN=123456789:telegram_bot_token_here

# Optional: OpenAI-powered /digest command
OPENAI_API_KEY=sk-your_openai_api_key_here

# Optional: restrict bot commands to specific Telegram user IDs
ALLOWED_USER_IDS=123456789,987654321

# Optional: scheduled auto-delivery target chats
TARGET_CHAT_IDS=-1001234567890,123456789

# Optional: heartbeat destination chats and cadence (0 disables)
HEARTBEAT_CHAT_IDS=-1001234567890
HEARTBEAT_INTERVAL_MINUTES=0

# Optional: scheduler timezone (IANA)
CRON_TIMEZONE=UTC

# Optional: health/metrics HTTP server
HEALTH_HOST=0.0.0.0
HEALTH_PORT=3001

# Optional: log format (json or text)
LOG_FORMAT=json

# Optional
NODE_ENV=development
